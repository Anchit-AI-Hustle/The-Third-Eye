# Copy to .env.local and fill in your values

# Required — AI responses (Gemini)
GEMINI_API_KEY=AIza...

# Optional — Whisper transcription
OPENAI_API_KEY=sk-...

# Optional — full web search (get key at serper.dev)
SERPER_API_KEY=...

# Required — Google sign-in + Calendar + Gmail
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Required — NextAuth
NEXTAUTH_SECRET=<run: openssl rand -base64 32>
NEXTAUTH_URL=http://localhost:3000

# Optional — Cross-device sync (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Premium / subscriptions — when these are unset the app runs as unlimited-free.
# Server-side Supabase (service role) powers tier lookup + usage metering.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Stripe (get keys at dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# Absolute URL of the deployed app (used for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reminder + daily-digest delivery (cron dispatcher)
# Encrypts stored Google refresh tokens (any string; hashed to 32 bytes)
TOKEN_ENCRYPTION_KEY=<run: openssl rand -base64 32>
# Protects /api/cron/dispatch (Vercel Cron sends it as a Bearer token)
CRON_SECRET=<run: openssl rand -base64 32>
# Web push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Confirm-then-act: turn on real enforcement of the freemium paywall (default off)
# ENFORCE_PREMIUM=1

# QA billing bypass — entering this code on /plans unlocks all paid features
# without payment (testing only; NOT a security control). Unset => bypass off.
NEXT_PUBLIC_TEST_UNLOCK_CODE=2803

# Extra FREE LLM providers for the cascade (all optional; add any to gain fallback):
#   Groq        — console.groq.com  (fast, generous free tier)   → GROQ_API_KEY
#   Cerebras    — cloud.cerebras.ai (very fast, free tier)       → CEREBRAS_API_KEY
#   OpenRouter  — openrouter.ai/keys (one key, many :free models)→ OPENROUTER_API_KEY
#   Mistral     — console.mistral.ai (free tier)                 → MISTRAL_API_KEY
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
MISTRAL_API_KEY=

# ── Music generation (Music Studio) ─────────────────────────────────────────
# Primary: Replicate (stable-audio for instrumental, ace-step for vocals).
#   REPLICATE_API_TOKEN — replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# MUSIC_SONG_MODEL=lucataco/ace-step
#
# Free fallback: HuggingFace serverless Inference (MusicGen, instrumental only).
# Used automatically when Replicate is missing or throttled/out-of-credit.
#   HF_API_TOKEN — huggingface.co/settings/tokens (a free "read" token works)
HF_API_TOKEN=
# HF_MUSIC_MODEL=facebook/musicgen-small   # or facebook/musicgen-large for higher quality
